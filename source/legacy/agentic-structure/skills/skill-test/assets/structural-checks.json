{
  "version": "1.0.0",
  "description": "Lint rules and validation data for skill-test structural checks",
  "rules": {
    "frontmatter": {
      "required-fields": ["name", "description", "metadata"],
      "metadata-required": [
        "author",
        "last-edit",
        "license",
        "version",
        "changelog",
        "scope",
        "auto-invoke"
      ]
    },
    "validation": {
      "version-format": "^\\d+\\.\\d+\\.\\d+$",
      "date-format": "^\\d{2}\\.\\d{2}\\.\\d{4}$",
      "allowed-scopes": [
        "[root]",
        "[ui]",
        "[storybook]",
        "[scripts]",
        "[docs]"
      ],
      "allowed-tools": [
        "Read",
        "Edit",
        "Write",
        "Grep",
        "Bash",
        "Node.js",
        "SubAgent",
        "Task"
      ]
    },
    "checks": [
      {
        "id": "frontmatter-valid",
        "description": "Frontmatter must be valid YAML between --- delimiters",
        "severity": "error"
      },
      {
        "id": "merge-conflicts",
        "description": "No merge conflict markers allowed (<<<<<<<, =======, >>>>>>>)",
        "severity": "error"
      },
      {
        "id": "required-fields",
        "description": "All required frontmatter fields must be present",
        "severity": "error"
      },
      {
        "id": "required-metadata",
        "description": "All required metadata fields must be present",
        "severity": "error"
      },
      {
        "id": "version-semver",
        "description": "Version must be in X.Y.Z format (semantic versioning)",
        "severity": "error"
      },
      {
        "id": "date-format",
        "description": "last-edit must be in DD.MM.YYYY format",
        "severity": "warning"
      },
      {
        "id": "valid-scope",
        "description": "scope field must contain allowed scope values",
        "severity": "error"
      },
      {
        "id": "file-references",
        "description": "All referenced files in assets/ and references/ must exist",
        "severity": "error"
      },
      {
        "id": "agents-md-consistency",
        "description": "Skill must be referenced in AGENTS.md if published",
        "severity": "warning"
      },
      {
        "id": "auto-invoke-consistency",
        "description": "If auto-invoke is set, skill must appear in AGENTS.md auto-invoke table",
        "severity": "warning"
      }
    ]
  }
}
