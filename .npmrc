# Shared (honored by both npm and pnpm)
ignore-scripts=true
engine-strict=true

# pnpm-only settings. npm 10/11 emit "Unknown project config" warnings for these;
# they are harmless today but slated for removal in a future npm major. Revisit
# placement once npm publishes its config validator changes.
strict-peer-dependencies=true
verify-store-integrity=true
auto-install-peers=false
prefer-frozen-lockfile=true
node-linker=isolated
